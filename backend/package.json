{
    "name": "backend",
    "version": "1.0.0",
    "private": true,
    "description": "cooking web app backend",
    "main": "app.js",
    "repository": "https://github.com/awslabs/aws-sam-cli/tree/develop/samcli/local/init/templates/cookiecutter-aws-sam-hello-nodejs",
    "author": "Alessio Caggiano, Francesco Ostidich, Matteo Bettiati",
    "license": "MIT",
    "scripts": {
        "dev": "npm run db:start && npm run db:gui && npm run start",
        "ship": "npm run build && npm run deploy",
        "build": "cd .. && sam build",
        "start": "cd .. && sam local start-api",
        "deploy": "cd .. && sam deploy",
        "test": "jest tests/unit",
        "test:watch": "jest --watch tests/unit",
        "test:coverage": "jest tests/unit --coverage",
        "db:start": "cd .. && docker-compose up -d",
        "db:stop": "cd .. && docker-compose stop",
        "db:gui": "open http://localhost:8001",
        "lint": "eslint 'src/**/*.ts' --quiet --fix",
        "format": "prettier --write 'src/**/*.ts'"
    },
    "dependencies": {
        "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
        "@aws-sdk/client-dynamodb": "^3.1000.0",
        "@aws-sdk/client-lambda": "^3.1000.0",
        "@aws-sdk/lib-dynamodb": "^3.1000.0",
        "esbuild": "^0.27.2"
    },
    "devDependencies": {
        "@jest/globals": "^29.2.0",
        "@types/aws-lambda": "^8.10.92",
        "@types/jest": "^29.2.0",
        "@types/node": "^20.5.7",
        "@typescript-eslint/eslint-plugin": "^5.10.2",
        "@typescript-eslint/parser": "^5.10.2",
        "eslint": "^8.8.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-prettier": "^4.0.0",
        "jest": "^29.2.1",
        "prettier": "^2.5.1",
        "ts-jest": "^29.0.5",
        "ts-node": "^10.9.1",
        "typescript": "^5.9.3"
    }
}
