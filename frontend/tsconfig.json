{
    "include": [
        "src"
    ],
    "compilerOptions": {
        "jsx": "react-jsx",
        "baseUrl": "./src",
        "paths": {
            "@components/*": [
                "components/*"
            ],
            "@pages/*": [
                "pages/*"
            ],
            "@context/*": [
                "context/*"
            ],
            "@api/*": [
                "api/*"
            ],
            "@shared/*": [
                "shared/*"
            ]
        }
    }
}
